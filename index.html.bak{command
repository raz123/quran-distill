  color: #fff;
}

.soura-info {
  flex: 1;
  min-width: 0;
}

.soura-name-en {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.3;
}

.soura-name-ar {
