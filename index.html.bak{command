  font-style: italic;
  line-height: 1.4;
}

.search-wrapper {
  padding: 12px 20px;
  border-bottom: 1px solid var(--border-color);
  flex-shrink: 0;
}

.search-input {
  width: 100%;
  padding: 9px 14px 9px 36px;
