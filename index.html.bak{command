  pointer-events: none;
}

.nav-btn-label {
  display: flex;
  flex-direction: column;
  line-height: 1.3;
}

.nav-btn-label small {
  font-size: 0.72rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.nav-btn:hover .nav-btn-label small { color: rgba(255,255,255,0.8); }

