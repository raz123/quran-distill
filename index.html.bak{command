  color: #fff;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  box-shadow: var(--shadow-md);
  opacity: 0;
  visibility: hidden;
  transform: translateY(10px);
  transition: all var(--transition-fast);
  z-index: 90;
}

.back-to-top.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.back-to-top:hover {
  background: var(--accent-gold-dark);
}

/* ===== Decorative ===== */
.divider-ornament {
  text-align: center;
  padding: 8px 0 12px;
  color: var(--accent-gold);
  font-size: 1.4rem;
  letter-spacing: 8px;
  opacity: 0.5;
}

/* ===== Responsive ===== */
@media (max-width: 860px) {
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    transform: translateX(-100%);
    box-shadow: var(--shadow-lg);
  }
  .sidebar.open { transform: translateX(0); }
  .sidebar-overlay.open { display: block; }
  .hamburger { display: flex; }
  .content-header, .content-body, .content-nav { padding-left: 24px; padding-right: 24px; }
  .soura-arabic-name { font-size: 2rem; }
  .soura-english-name { font-size: 1.2rem; }
}

@media (max-width: 500px) {
  .content-header { padding-top: 70px; }
  .soura-arabic-name { font-size: 1.7rem; }
  .soura-english-name { font-size: 1.05rem; }
  .soura-id-badge { width: 40px; height: 40px; line-height: 40px; font-size: 1rem; }
  .content-body { padding: 20px 20px 32px; }
  .content-nav { padding: 0 20px 32px; flex-direction: column; }
  .nav-btn { justify-content: center; }
}

/* ===== Print ===== */
@media print {
  .sidebar, .hamburger, .back-to-top, .sidebar-overlay, .content-nav { display: none !important; }
  .main { display: block; }
  .content-header { padding-top: 0; }
  body { background: #fff; color: #000; }
  .soura-arabic-name { color: #333; }
  .summary-text { font-size: 10.5pt; line-height: 1.7; }
  .meta-badge { border: 1px solid #999; background: none !important; color: #333 !important; }
  .soura-id-badge { background: none; color: #000; border: 2px solid #000; }
}
</style>
